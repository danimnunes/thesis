# By default, run the e2e tests against the remote server
TEST_ENV=remote

# Load secrets from 1Password
TEST_ISSUER_PRIVATE_KEY="op://env-$EBSI_ENV/root-tao/private-key"
TEST_ISSUER_KID="op://env-$EBSI_ENV/root-tao/kid-es256"
TEST_ISSUER_ATTRIBUTE="op://env-$EBSI_ENV/root-tao/accreditation"
TEST_ISSUER_ALG=ES256
TEST_TNT_AUTHORISED_USER_KID="op://env-$EBSI_ENV/tnt-authorised-user/kid"
TEST_TNT_AUTHORISED_USER_PRIVATE_KEY="op://env-$EBSI_ENV/tnt-authorised-user/private-key"

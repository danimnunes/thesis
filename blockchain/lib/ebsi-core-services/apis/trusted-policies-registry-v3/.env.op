# By default, run the e2e tests against the remote server
TEST_ENV=remote
TEST_ENABLE_WRITE_OPS=true

# Load secrets from 1Password
TEST_ADMIN_KID="op://env-$EBSI_ENV/tpr-operator/kid-es256"
TEST_ADMIN_PRIVATE_KEY="op://env-$EBSI_ENV/tpr-operator/private-key"
TEST_USER_KID="op://env-$EBSI_ENV/legal-entity-1/kid-es256"
TEST_USER_PRIVATE_KEY="op://env-$EBSI_ENV/legal-entity-1/private-key"
TEST_SUBJECT_ADDRESS="op://env-$EBSI_ENV/tpr-subject/address"

# Override .env settings for testing
# E.g. make sure all the tests run in "test" env
# You can override these settings by creating a new file called .env.test.local
DOMAIN=https://api-test.ebsi.eu
BESU_RPC_NODE=https://besu.local
BESU_READINESS_ENDPOINT=http://besu:8545/readiness
PROXY_FACTORY_CONTRACT_ADDR=0x48a11579fb469e62f698622C5e5bcBB6Fd3e1cCF
PROXY_TEMPLATE_CONTRACT_ADDR=0x28575Fe9C1B1E5878Fc63AfE1Aa8c4eeDE3A1B8a

# Env for e2e tests. Switch to remote API instance with `TEST_ENV=remote`
# TEST_ENV=

# Domain of a specific node in the network
# TEST_SPECIFIC_NODE_DOMAIN=

# By default, run the e2e tests against the remote server
TEST_ENV=remote
TEST_ENABLE_WRITE_OPS=true

# Load secrets from 1Password
TEST_ADMIN_KID="op://env-$EBSI_ENV/root-tao/kid-es256"
TEST_ADMIN_PRIVATE_KEY="op://env-$EBSI_ENV/root-tao/private-key"
TEST_ADMIN_ACCREDITATION="op://env-$EBSI_ENV/root-tao/accreditation"
TEST_ISSUER_WITH_PROXY_KID="op://env-$EBSI_ENV/trusted-issuer/kid-es256"
TEST_ISSUER_WITH_PROXY_PRIVATE_KEY="op://env-$EBSI_ENV/trusted-issuer/private-key"

# Override .env settings for testing
# E.g. make sure all the tests run in "test" env
# You can override these settings by creating a new file called .env.test.local
NETWORK=test
DOMAIN=https://api-test.ebsi.eu
BESU_RPC_NODE=https://besu.local
BESU_READINESS_ENDPOINT=http://besu:8545/readiness
CONTRACT_ADDR=0xCb9e9F0229f1492A22801B176196eCb158eb24B0

# Test Admin -> Legal entity whose DID document is registered in the DID Registry.
# Does not need to be a Trusted Issuer. Has all the existing policies related to the
# subject under test (e.g. Timestamp SC -> TS:insertHashAlgorithm + TS:updateHashAlgorithm)
# Used for e2e tests.
# TEST_ADMIN_KID=
# TEST_ADMIN_PRIVATE_KEY=

# Test User -> Legal entity whose DID document is registered in the DID Registry.
# Does not need to be a Trusted Issuer. Doesn't have any specific policies.
# TEST_USER_KID=
# TEST_USER_PRIVATE_KEY=

# Env for e2e tests. Switch to remote API instance with `TEST_ENV=remote`
# TEST_ENV=

# Domain of a specific node in the network
# TEST_SPECIFIC_NODE_DOMAIN=

# Set `TEST_ENABLE_WRITE_OPS=true` to enable write operations during the tests
# TEST_ENABLE_WRITE_OPS=

# Test Blockscout
# BLOCKSCOUT_URL=
# BLOCKSCOUT_BEARER_TOKEN=

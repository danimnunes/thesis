# By default, run the e2e tests against the remote server
TEST_ENV=remote
TEST_ENABLE_WRITE_OPS=true

# Load secrets from 1Password
TEST_AUTH_API_V4_ES256_PRIVATE_KEY="op://env-$EBSI_ENV/authorisation-api-v4/private-key"
TEST_AUTHORISED_LEGAL_ENTITY_KID="op://env-$EBSI_ENV/tnt-authorised-user/kid"
TEST_AUTHORISED_LEGAL_ENTITY_PRIVATE_KEY="op://env-$EBSI_ENV/tnt-authorised-user/private-key"
TEST_AUTHORISED_LEGAL_ENTITY_VC_TO_ONBOARD="op://env-$EBSI_ENV/tnt-authorised-user/vc-to-onboard"
TEST_REGULAR_LEGAL_ENTITY_KID="op://env-$EBSI_ENV/legal-entity-2/kid"
TEST_REGULAR_LEGAL_ENTITY_PRIVATE_KEY="op://env-$EBSI_ENV/legal-entity-2/private-key"
TEST_DOC_WITH_EVENTS="op://env-$EBSI_ENV/tnt-api-v1/doc-with-events"

{
  "name": "@ebsiint-sc/beacon-proxy",
  "private": true,
  "version": "1.0.0-rc.0",
  "license": "EUPL-1.2",
  "scripts": {
    "clean": "rimraf artifacts cache",
    "build": "pnpm run compile",
    "compile": "hardhat compile && pnpm exec tsc --project tsconfig.build.json && copyfiles -f src/types/hardhat.d.ts dist",
    "coverage": "pnpm exec hardhat coverage --network coverage",
    "lint": "pnpm run lint:prettier && pnpm run lint:eslint && pnpm run lint:sol",
    "lint:prettier": "prettier . --check && pnpm exec prettier --list-different --plugin=prettier-plugin-solidity \"contracts/**/*.sol\"",
    "lint:write": "prettier . --write && pnpm exec prettier --write --plugin=prettier-plugin-solidity \"contracts/**/*.sol\"",
    "lint:eslint": "eslint .",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "test": "hardhat test",
    "setup": "exit 0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.6.1"
  },
  "devDependencies": {
    "@gnosis-guild/typechain-ethers-v6": "0.5.5",
    "@gnosis-guild/typechain-hardhat": "9.2.2",
    "@nomicfoundation/hardhat-chai-matchers": "2.1.0",
    "@nomicfoundation/hardhat-ethers": "3.1.0",
    "@nomiclabs/hardhat-solhint": "4.1.2",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.0",
    "chai": "4.5.0",
    "ethers": "6.16.0",
    "hardhat": "2.26.1",
    "hardhat-abi-exporter": "2.11.0",
    "solidity-coverage": "0.8.17",
    "typechain": "8.3.2"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/artifacts",
          "{projectRoot}/dist",
          "{projectRoot}/src"
        ]
      },
      "lint": {
        "dependsOn": [
          "build"
        ]
      },
      "test:unit": {
        "dependsOn": [
          "build"
        ]
      },
      "test:ci": {
        "dependsOn": [
          "build"
        ]
      }
    }
  }
}

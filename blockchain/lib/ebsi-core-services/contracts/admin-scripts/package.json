{
  "name": "@ebsiint-sc/admin-scripts",
  "private": true,
  "version": "2.0.0-rc.12",
  "license": "EUPL-1.2",
  "scripts": {
    "clean": "rimraf artifacts cache src",
    "fork": "hardhat node --fork https://eth-mainnet.alchemyapi.io/v2/GVQRQezmyi7tO268bhIl5CSo6lM9ubfp --fork-block-number 11095000",
    "prettier-format": "prettier . --write",
    "setup": "exit 0",
    "prepare-contracts": "scripts/prepare-contracts.sh",
    "compile": "pnpm run prepare-contracts && hardhat --config hardhat.config.compiler.ts compile",
    "lint": "pnpm run lint:prettier && pnpm run lint:eslint && pnpm run lint:tsc",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc --noEmit --incremental false",
    "lint:prettier": "prettier . --check",
    "box": "scripts/deploy-box.sh",
    "deploy-box": "pnpm run && pnpm run compile && pnpm run box"
  },
